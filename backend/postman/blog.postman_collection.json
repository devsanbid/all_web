              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('login response contains token', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data).to.have.property('token').that.is.a('string').and.is.not.empty;",
              "});",
              "",
              "pm.collectionVariables.set('authToken', json.data.token);",
              "pm.collectionVariables.set('userId', json.data.user._id);"
            ],
            "type": "text/javascript"
          }
        }
