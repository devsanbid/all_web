  "item": [
    {
      "name": "Auth - Register Test User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const stamp = Date.now();",
              "pm.collectionVariables.set('testEmail', `blog.user.${stamp}@example.com`);",
              "pm.collectionVariables.set('testUsername', `bloguser${stamp}`);",
              "pm.collectionVariables.set('testPassword', 'password123');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('register returns 201 or existing-user 400', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('register response has success flag', function () {",
              "  pm.expect(json).to.have.property('success');",
              "});",
              "",
              "if (pm.response.code === 201) {",
              "  pm.test('created user has email', function () {",
              "    pm.expect(json.data.email).to.eql(pm.collectionVariables.get('testEmail'));",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Blog\",\n  \"lastName\": \"Tester\",\n  \"email\": \"{{testEmail}}\",\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Auth - Login Test User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login returns 200', function () {",
