    {
      "name": "Blog - List Paginated Blogs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('list blogs returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('list blogs response has data and pagination meta', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data).to.be.an('array');",
              "  pm.expect(json.meta).to.include.keys(['total', 'page', 'limit', 'totalPages']);",
              "  pm.expect(json.meta.page).to.eql(1);",
              "  pm.expect(json.meta.limit).to.eql(10);",
              "});",
              "",
              "pm.test('created blog appears in paginated list when within first page', function () {",
              "  if (json.data.length < 10) {",
              "    const createdBlog = json.data.find((blog) => blog._id === pm.collectionVariables.get('blogId'));",
              "    pm.expect(createdBlog).to.exist;",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/blogs?page=1&limit=10",
