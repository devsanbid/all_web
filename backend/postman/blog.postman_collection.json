    {
      "name": "Blog - Create Blog",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('blogTitle', `Postman Blog ${Date.now()}`);",
              "pm.collectionVariables.set('blogContent', 'This blog was created from a Postman automated test case.');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('create blog returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('create blog response is successful', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.message).to.eql('Blog created successfully');",
              "});",
              "",
              "pm.test('created blog has expected fields', function () {",
              "  pm.expect(json.data.title).to.eql(pm.collectionVariables.get('blogTitle'));",
              "  pm.expect(json.data.content).to.eql(pm.collectionVariables.get('blogContent'));",
              "  pm.expect(json.data.authorId).to.eql(pm.collectionVariables.get('userId'));",
              "  pm.expect(json.data).to.have.property('_id');",
              "});",
              "",
              "pm.collectionVariables.set('blogId', json.data._id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
